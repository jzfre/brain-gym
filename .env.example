# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://brain:brain@localhost:5438/brain_gym?schema=public"

# OpenAI
OPENAI_API_KEY="sk-replace-me"
OPENAI_MODEL="gpt-5.5"
OPENAI_REASONING_EFFORT="medium"
# Per-attempt ceiling for OpenAI calls, in milliseconds (SDK default of 10
# minutes is too tight for high reasoning effort + web_search). The client
# makes up to 2 attempts, so worst case is ~2x this per model call.
OPENAI_TIMEOUT_MS="1200000"

# Local single-user MVP
LOCAL_USER_ID="00000000-0000-0000-0000-000000000001"
LOCAL_USER_EMAIL="local@brain-gym.dev"
LOCAL_USER_DISPLAY_NAME="Local User"

# Single-password gate (required). Change-me before first use.
APP_PASSWORD="change-me"

# Host port that the Docker app container binds to. Point your reverse
# proxy (NGINX, Cloudflare Tunnel, etc.) at this port.
APP_PORT=3111

# Semantic duplicate prevention
EMBEDDING_MODEL="text-embedding-3-small"
DEDUP_SIMILARITY_THRESHOLD="0.85"
DEDUP_MAX_RETRIES="3"
DEDUP_NEIGHBOR_K="5"
